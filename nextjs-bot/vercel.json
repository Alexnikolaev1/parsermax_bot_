{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron/digest", "schedule": "0 * * * *" },
    { "path": "/api/cron/health", "schedule": "0 6 * * *" }
  ],
  "functions": {
    "src/app/api/search/instant/route.ts": { "maxDuration": 25 },
    "src/app/api/bot/webhook/route.ts":   { "maxDuration": 25 },
    "src/app/api/bot/setup/route.ts":     { "maxDuration": 15 },
    "src/app/api/cron/digest/route.ts":   { "maxDuration": 60 },
    "src/app/api/cron/scrape/route.ts":   { "maxDuration": 60 }
  }
}
