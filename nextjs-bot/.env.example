# --- MAX Messenger ---
MAX_BOT_TOKEN=             # от @MasterBot
MAX_WEBHOOK_SECRET=        # любой случайный 32+ символа; будет в Authorization header webhook'а

# --- LLM (один из двух) ---
# Lovable AI Gateway (бесплатный квота, Gemini/GPT-5):
LOVABLE_API_KEY=
LLM_BASE_URL=https://ai.gateway.lovable.dev/v1
LLM_MODEL=google/gemini-3-flash-preview
# Или OpenAI напрямую:
# OPENAI_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Storage (Upstash REST Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Telegram worker (отдельный сервис) ---
TG_WORKER_URL=             # напр. https://my-tg-worker.up.railway.app
TG_WORKER_TOKEN=           # любой случайный, должен совпадать с воркером

# --- Vercel Cron ---
CRON_SECRET=               # Vercel автоматически передаёт в Authorization: Bearer <CRON_SECRET>

# --- Опционально ---
# INSTANT_API_SECRET=        # Bearer для /api/search/instant (иначе CRON_SECRET)
# DEFAULT_HOURS_BACK=6
# RATE_LIMIT_PER_MIN=10
# MAX_MESSAGE_CHARS=3800
# WARMUP_QUERIES=путин,нейросети
# YOUTUBE_API_KEY=
